{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git backup:*)",
      "Bash(git branch backup/:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/warn-mod-rs.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-perl.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-subagent-model.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun x ccusage statusline",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "probitas@probitas-test": true
  },
  "extraKnownMarketplaces": {
    "probitas-test": {
      "source": {
        "source": "github",
        "repo": "probitas-test/claude-plugins"
      }
    },
    "cclens": {
      "source": {
        "source": "directory",
        "path": "/Users/alisue/ogh/lambdalisue/cclens"
      }
    }
  },
  "effortLevel": "high",
  "advisorModel": "opus",
  "tui": "default",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "verbose": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
